{
  "expo": {
    "name": "Ask Arthur",
    "slug": "ask-arthur",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "askarthur",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#001F3F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "au.askarthur.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Ask Arthur needs camera access to scan QR codes for scam detection.",
        "NSPrivacyCollectedDataTypes": [
          {
            "NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeOtherUserContent",
            "NSPrivacyCollectedDataTypeLinked": false,
            "NSPrivacyCollectedDataTypeTracking": false,
            "NSPrivacyCollectedDataTypePurposes": [
              "NSPrivacyCollectedDataTypePurposeAppFunctionality"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#001F3F"
      },
      "package": "au.askarthur.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.QUERY_ALL_PACKAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Ask Arthur needs camera access to scan QR codes for scam detection."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#001F3F"
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 5
          },
          "androidIntentFilters": [
            "text/*",
            "image/*"
          ]
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21a9c339-8761-450c-ae1f-1b89b5e904d0"
      }
    },
    "owner": "bren.apps"
  }
}
