# ──────────────────────────────────────────────
# Ask Arthur — Environment Variables
# Copy to .env.local and fill in your values
# ──────────────────────────────────────────────

# ── Claude AI (required for scam analysis) ──
ANTHROPIC_API_KEY=

# ── Upstash Redis (required for rate limiting) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Supabase (required for waitlist + scam storage) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Personal access token for the local Supabase MCP server (read-only via .mcp.json).
# Generate at https://supabase.com/dashboard/account/tokens. Required only for the
# local Claude Code MCP integration — production code paths use SUPABASE_SERVICE_ROLE_KEY.
# Export in your shell (.zshrc/.zprofile) so Claude Code picks it up on session start.
SUPABASE_ACCESS_TOKEN=

# ── Resend (required for welcome + weekly emails) ──
RESEND_API_KEY=
RESEND_FROM_EMAIL="Ask Arthur <brendan@askarthur.au>"

# ── URL Reputation (optional — enhances detection) ──
GOOGLE_SAFE_BROWSING_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Cloudflare R2 (required for screenshot storage) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=askarthur-screenshots

# ── Cron authentication ──
CRON_SECRET=

# ── Bot queue webhook (Supabase Database Webhook → /api/bot-webhook) ──
# Setup in Supabase dashboard → Database → Webhooks on bot_message_queue
# INSERT events. Must be set to the same value on both sides.
# Generate with: openssl rand -hex 32
SUPABASE_WEBHOOK_SECRET=

# ── Admin cost telemetry alerts (Telegram) ──
# Personal chat ID (get via @userinfobot). Kept separate from user-bot
# chats so admin DMs don't spam users.
TELEGRAM_ADMIN_CHAT_ID=
# Daily spend above this (USD) triggers a Telegram alert from
# /api/cron/cost-daily-check. Default 2.
DAILY_COST_THRESHOLD_USD=2

# ── B2B Threat API ──
# API keys are stored as SHA-256 hashes in the api_keys table
# No env var needed — keys are managed via Supabase

# ── Prompt traceability ──
PROMPT_VERSION=2.0.0

# ── Phase 1: Media Analysis ──
NEXT_PUBLIC_FF_MEDIA_ANALYSIS=false
OPENAI_API_KEY=

# ── Phase 2 Feature Flags (default: all OFF) ──
NEXT_PUBLIC_FF_DEEPFAKE=false
NEXT_PUBLIC_FF_PHONE_INTEL=false
NEXT_PUBLIC_FF_VIDEO_UPLOAD=false

# ── Phase 2: Deepfake Detection ──
REALITY_DEFENDER_API_KEY=
RESEMBLE_AI_API_TOKEN=

# ── Phase 2: Phone Intelligence (Twilio Lookup v2) ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Extension: Facebook Ads scanning (server gate) ──
# Must match the client-side build-time flag WXT_FACEBOOK_ADS. When false,
# /api/extension/analyze-ad returns 503 even for valid signed requests.
NEXT_PUBLIC_FF_FACEBOOK_ADS=false

# ── Hive AI (Facebook ad image scanning + right-click image check) ──
# Only called when a flagged ad has an image, or on a right-click image
# check. Pricing contract pending; PRICING.HIVE_AI_USD_PER_IMAGE currently
# uses the $0.003 published self-serve rate. Without this key, image checks
# return checked:false / scan_unavailable.
HIVE_API_KEY=
# Daily vendor cost brakes (bare numbers — "$5" parses to NaN and disables
# the brake). Both default sensibly if unset; see cost-daily-check.
HIVE_AI_CAP_USD=5
EXTENSION_IMAGE_CHECK_CAP_USD=5

# ── Right-click image check (image-check v2) ──
# Local testing runbook: docs/ops/image-check-local-testing.md
# Route gate; pairs with the WXT_IMAGE_CHECK extension build flag.
NEXT_PUBLIC_FF_IMAGE_CHECK=false
# Claude-vision context pass (what the image depicts + celebrity match).
# Launches ON with the route flag — see the activation runbook.
FF_IMAGE_CHECK_VISION=false
# Evidence records (ADR-0022: metadata-only, flagged-only, never bytes).
# Also gates /image-check/[ref], its PDF, and /api/v1/image-checks.
FF_IMAGE_CHECK_RECORDS=false

# ── Stripe core (required for any paid checkout) ──
# Server-side only. The app uses Stripe Checkout Sessions (server-redirect),
# so a publishable key is NOT currently wired — the placeholder below is here
# only because it's the standard Stripe pair; nothing reads it yet.
STRIPE_SECRET_KEY=                       # sk_test_... (test mode) / sk_live_...
STRIPE_WEBHOOK_SECRET=                    # whsec_... from the Stripe webhook endpoint
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=       # pk_test_... — placeholder, not yet consumed by code

# ── Extension billing (Extension Pro, A$4.99/mo) ──
NEXT_PUBLIC_FF_EXTENSION_BILLING=false
NEXT_PUBLIC_STRIPE_EXTENSION_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_EXTENSION_PRO_ANNUAL=

# ── Brand Monitor billing (clone-watch Wave 3, PR #814) ──
# Price IDs are pasted after the two Stripe products are created (AUD,
# GST-inclusive, automatic_tax). brand_pilot (A$300/mo) is manual billing —
# no Stripe product, so it has no var here.
NEXT_PUBLIC_STRIPE_BRAND_MONITOR_MONTHLY=       # price_... — A$1,950/mo
NEXT_PUBLIC_STRIPE_BRAND_MONITOR_PLUS_MONTHLY=  # price_... — A$2,950/mo

# ── Phase 3: Scam Contact Database ──
NEXT_PUBLIC_FF_SCAM_REPORTING=false

# ── Newsletter ──
NEXT_PUBLIC_FF_NEWSLETTER=false

# ── Business Details ──
NEXT_PUBLIC_ABN=

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# ── WhatsApp Bot (Cloud API) ──
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=

# ── Facebook Messenger Bot (Meta Platform) ──
# The Messenger scam-check bot is code-complete (apps/web/lib/bots/messenger/*,
# webhook at /api/webhooks/messenger); these gate it live. Activation runbook:
# docs/ops/meta-bots-config.md. VERIFY_TOKEN is your own arbitrary shared secret
# echoed back on the GET subscribe handshake; PAGE_ACCESS_TOKEN + APP_SECRET
# come from the Meta app (Messenger product → your Page).
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=
MESSENGER_APP_SECRET=

# ── Meta Brand Rights Protection (report-to-Meta takedown) ──
# CONDITIONAL / brand-gated. The only programmatic Meta takedown path is the IP
# Reporting API inside BRP, usable ONLY for a rights-holder's OWN registered
# trademark (see docs/plans/meta-brp-report-to-meta.md + ADR-0023). Unused in
# code today — reserved until a pilot brand authorises Ask Arthur as agent.
META_BRP_ACCESS_TOKEN=

# ── Slack Bot ──
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# ── HIBP Breach Check ($4.50/mo Pwned 1 plan) ──
HIBP_API_KEY=

# ── Mobile App ──
EXPO_PUBLIC_API_URL=https://askarthur.au
