{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/branch-check.sh",
            "timeout": 10,
            "statusMessage": "Verifying git branch (CLAUDE.md ship workflow)…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/run-reviewer.sh",
            "timeout": 15,
            "statusMessage": "Reviewing edit against Critical Rules…"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "find /tmp -maxdepth 1 -name '.claude-branch-checked-*' -mtime +0 -delete 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/propose-claudemd-update.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
