      "boundElements": null,
      "updated": 1777368698159,
      "link": null,
      "locked": false,
      "text": "\u2022 Six anti-scam penalties\n  2024\u20132026\n\u2022 Drafting mandatory standard\n  (after rejecting ATA's draft\n  twice)\n\u2022 Operates SMS Sender ID\n  Register (live 1 Jul 2026)",
      "originalText": "\u2022 Six anti-scam penalties\n  2024\u20132026\n\u2022 Drafting mandatory standard\n  (after rejecting ATA's draft\n  twice)\n\u2022 Operates SMS Sender ID\n  Register (live 1 Jul 2026)",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "baseline": 11
